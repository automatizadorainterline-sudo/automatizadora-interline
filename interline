</symbol>

<symbol id="icon-face" viewBox="0 0 48 48">
  <path d="M6 14 V6 H14"/>
  <path d="M34 6 H42 V14"/>
  <path d="M42 34 V42 H34"/>
  <path d="M14 42 H6 V34"/>
  <circle cx="24" cy="22" r="9"/>
  <circle class="dot" cx="20.5" cy="20" r="1.3"/>
  <circle class="dot" cx="27.5" cy="20" r="1.3"/>
  <path d="M19 26 Q24 30 29 26"/>
