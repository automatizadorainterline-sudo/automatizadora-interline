<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Automatizadora Interline — Automação e Segurança Eletrônica</title>
<meta name="description" content="Instalação de câmeras de segurança, portões automáticos, cerca elétrica e reconhecimento facial. Projeto, instalação e suporte completo em automação e segurança eletrônica.">
<meta name="theme-color" content="#0A0F1A">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>

:root{
  --bg-deep:#0A0F1A;
  --bg-panel:#111A2B;
  --bg-panel-2:#16213A;
  --line: rgba(255,255,255,.08);
  --line-strong: rgba(255,255,255,.16);
  --text-1:#EAF0F7;
  --text-2:#9AA7BD;
  --text-3:#677289;
  --amber:#FFB020;
  --teal:#2DD4BF;
  --container:1180px;
}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;}
body{background:var(--bg-deep);color:var(--text-1);font-family:'Inter',sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
img,svg{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}
ul{list-style:none;}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
:focus-visible{outline:2px solid var(--teal);outline-offset:3px;border-radius:2px;}

.container{width:100%;max-width:var(--container);margin:0 auto;padding:0 24px;position:relative;z-index:1;}
section{position:relative;padding:100px 0;}
@media (max-width:640px){section{padding:68px 0;}}

h1,h2,h3{font-family:'Space Grotesk',sans-serif;font-weight:600;line-height:1.15;letter-spacing:-0.01em;color:var(--text-1);}
.mono{font-family:'IBM Plex Mono',monospace;}

.eyebrow{font-family:'IBM Plex Mono',monospace;font-size:12.5px;font-weight:500;letter-spacing:.12em;color:var(--amber);display:inline-flex;align-items:center;gap:2px;margin-bottom:16px;}
.eyebrow::before{content:'[';opacity:.55;}
.eyebrow::after{content:']';opacity:.55;}
.eyebrow.teal{color:var(--teal);}

.section-head{max-width:640px;margin-bottom:56px;}
.section-head h2{font-size:clamp(28px,4vw,40px);margin-bottom:16px;}
.section-head p{color:var(--text-2);font-size:16.5px;}
.section-head.center{margin-inline:auto;text-align:center;}

.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.6;
  background-image:linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size:42px 42px;
  -webkit-mask-image:radial-gradient(circle at 50% 0%, black, transparent 75%);
  mask-image:radial-gradient(circle at 50% 0%, black, transparent 75%);
}

/* ---------- Buttons ---------- */
.btn{display:inline-flex;align-items:center;gap:9px;padding:14px 26px;border-radius:6px;font-family:'Space Grotesk';font-weight:600;font-size:15px;transition:transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease, color .25s ease;white-space:nowrap;}
.btn svg{width:18px;height:18px;}
.btn-primary{background:var(--amber);color:#1A1304;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px -8px rgba(255,176,32,.55);}
.btn-outline{border:1.5px solid var(--line-strong);color:var(--text-1);}
.btn-outline:hover{border-color:var(--teal);color:var(--teal);}
.btn-sm{padding:11px 20px;font-size:13.5px;}
.btn-block{width:100%;justify-content:center;}

/* ---------- Header ---------- */
.site-header{position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 0;transition:background .3s ease, border-color .3s ease, padding .3s ease;border-bottom:1px solid transparent;}
.site-header.is-scrolled{background:rgba(10,15,26,.86);backdrop-filter:blur(10px);border-bottom-color:var(--line);padding:14px 0;}
.header-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;}
.brand{display:flex;align-items:center;gap:10px;}
.logo-mark{width:34px;height:34px;color:var(--amber);flex-shrink:0;}
.brand-text{display:flex;flex-direction:column;line-height:1.15;}
.brand-text strong{font-family:'Space Grotesk';font-size:18px;font-weight:700;}
.brand-text span{font-family:'IBM Plex Mono';font-size:9.5px;color:var(--text-3);letter-spacing:.12em;}

.site-nav{display:flex;align-items:center;gap:30px;}
.nav-link{font-size:14.5px;color:var(--text-2);transition:color .2s ease;}
.nav-link:hover{color:var(--text-1);}
.header-actions{display:flex;align-items:center;gap:16px;}
.nav-toggle{display:none;width:44px;height:44px;position:relative;flex-shrink:0;}
.nav-toggle span{position:absolute;left:11px;right:11px;height:2px;background:var(--text-1);transition:transform .25s ease, opacity .25s ease;}
.nav-toggle span:nth-child(1){top:15px;}
.nav-toggle span:nth-child(2){top:21px;}
.nav-toggle span:nth-child(3){top:27px;}
.nav-toggle.is-active span:nth-child(1){transform:translateY(6px) rotate(45deg);}
.nav-toggle.is-active span:nth-child(2){opacity:0;}
.nav-toggle.is-active span:nth-child(3){transform:translateY(-6px) rotate(-45deg);}

@media (max-width:860px){
  .site-nav{position:fixed;top:0;right:0;height:100vh;width:280px;background:var(--bg-panel);flex-direction:column;align-items:flex-start;padding:100px 32px 40px;gap:28px;transform:translateX(100%);transition:transform .35s ease;border-left:1px solid var(--line);overflow-y:auto;}
  .site-nav.is-open{transform:translateX(0);}
  .nav-toggle{display:block;}
  .header-actions .btn{display:none;}
  .site-nav .btn-primary{display:inline-flex;margin-top:8px;}
}

/* ---------- Hero ---------- */
.hero{padding-top:172px;padding-bottom:76px;overflow:hidden;}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:center;}
@media (max-width:980px){
  .hero{padding-top:140px;}
  .hero-grid{grid-template-columns:1fr;}
  .hero-visual{order:-1;max-width:360px;margin:0 auto 12px;}
}
.hero h1{font-size:clamp(34px,5vw,55px);margin-bottom:22px;}
.hero h1 .accent{color:var(--amber);}
.hero-lead{font-size:18px;color:var(--text-2);max-width:520px;margin-bottom:34px;}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;}

.hero-visual{position:relative;display:flex;justify-content:center;}
.hero-visual::before{content:'';position:absolute;width:420px;height:420px;background:radial-gradient(circle, rgba(255,176,32,.16), transparent 70%);filter:blur(8px);z-index:0;}
.hero-visual::after{content:'';position:absolute;right:-10px;bottom:-10px;width:300px;height:300px;background:radial-gradient(circle, rgba(45,212,191,.15), transparent 70%);filter:blur(8px);z-index:0;}
.hero-schematic{position:relative;z-index:1;width:100%;max-width:480px;}

.flow-line{fill:none;}
.flow-line.amber{stroke:rgba(255,176,32,.55);stroke-width:1.6;stroke-dasharray:5 7;animation:flow 1.6s linear infinite;}
.flow-line.teal{stroke:rgba(45,212,191,.55);stroke-width:1.6;stroke-dasharray:5 7;animation:flow 1.6s linear infinite;}
@keyframes flow{to{stroke-dashoffset:-24;}}

.node-bg{fill:var(--bg-panel);stroke-width:1.5;}
.node.amber .node-bg{stroke:rgba(255,176,32,.45);}
.node.teal .node-bg{stroke:rgba(45,212,191,.45);}
.node-pulse{fill:none;stroke-width:1.4;transform-box:fill-box;transform-origin:center;animation:pulsering 2.6s ease-out infinite;}
.node.amber .node-pulse{stroke:var(--amber);}
.node.teal .node-pulse{stroke:var(--teal);}
@keyframes pulsering{0%{transform:scale(.82);opacity:.55;}75%{transform:scale(1.2);opacity:0;}100%{opacity:0;}}
.node-icon.amber{color:var(--amber);}
.node-icon.teal{color:var(--teal);}
.node-icon path,.node-icon line,.node-icon rect,.node-icon circle,.node-icon polyline{fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.node-icon .dot{fill:currentColor;stroke:none;}
.node-label{font-family:'IBM Plex Mono';font-size:11px;fill:var(--text-3);text-anchor:middle;letter-spacing:.04em;}
.hub-circle{fill:var(--bg-panel-2);stroke:var(--line-strong);stroke-width:1.5;}
.hub-icon path,.hub-icon line,.hub-icon circle{fill:none;stroke:var(--text-1);stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;}
.hub-label{font-family:'Space Grotesk';font-size:13px;font-weight:700;fill:var(--text-1);text-anchor:middle;}
.hub-sub{font-family:'IBM Plex Mono';font-size:8.5px;fill:var(--text-3);text-anchor:middle;letter-spacing:.08em;}

/* generic icon helper */
.icon{width:30px;height:30px;}
.icon path,.icon line,.icon rect,.icon circle,.icon polyline,.icon polygon{fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.icon .dot{fill:currentColor;stroke:none;}

/* ---------- Catalog ---------- */
.catalog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
@media (max-width:980px){.catalog-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:640px){.catalog-grid{grid-template-columns:1fr;}}

.card-service{--accent:var(--amber);--accent-soft:rgba(255,176,32,.12);--accent-ink:#1A1304;background:var(--bg-panel);border:1px solid var(--line);border-radius:10px;padding:30px 26px;display:flex;flex-direction:column;transition:transform .3s ease, border-color .3s ease, background .3s ease, box-shadow .3s ease;}
.card-service:hover{transform:translateY(-6px) scale(1.03);border-color:var(--accent);background:var(--bg-panel-2);box-shadow:0 20px 44px -16px rgba(0,0,0,.5);}
.card-service.accent-teal{--accent:var(--teal);--accent-soft:rgba(45,212,191,.12);--accent-ink:#042722;}

.card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;}
.card-code{font-family:'IBM Plex Mono';font-size:12px;color:var(--accent);letter-spacing:.06em;padding-top:6px;}
.card-icon-frame{position:relative;width:60px;height:60px;display:flex;align-items:center;justify-content:center;background:var(--accent-soft);border-radius:8px;color:var(--accent);}
.card-icon-frame::before,.card-icon-frame::after{content:'';position:absolute;width:13px;height:13px;border-color:var(--accent);}
.card-icon-frame::before{top:-5px;left:-5px;border-top:2px solid;border-left:2px solid;}
.card-icon-frame::after{bottom:-5px;right:-5px;border-bottom:2px solid;border-right:2px solid;}
.card-icon-frame .icon{width:30px;height:30px;}

.card-service h3{font-size:19px;margin-bottom:10px;}
.card-service p{color:var(--text-2);font-size:14.5px;margin-bottom:18px;}
.card-features{display:flex;flex-direction:column;gap:9px;margin-bottom:26px;}
.card-features li{display:flex;gap:10px;font-size:13.5px;color:var(--text-2);align-items:flex-start;}
.card-features li::before{content:'';width:6px;height:6px;margin-top:6px;background:var(--accent);flex-shrink:0;border-radius:1px;transform:rotate(45deg);}
.card-cta{margin-top:auto;display:flex;align-items:center;justify-content:center;gap:8px;font-size:14.5px;font-weight:700;font-family:'Space Grotesk';color:var(--accent-ink);background:var(--accent);width:100%;padding:14px 18px;border-radius:7px;transition:transform .25s ease, box-shadow .25s ease, filter .2s ease;}
.card-cta svg{width:16px;height:16px;transition:transform .2s ease;}
.card-cta:hover{transform:translateY(-2px);box-shadow:0 14px 30px -10px var(--accent);filter:brightness(1.07);}
.card-cta:hover svg{transform:translateX(3px);}

.card-service.placeholder{background:transparent;border:1.5px dashed var(--line-strong);align-items:center;text-align:center;justify-content:center;}
.card-service.placeholder .card-icon-frame{background:transparent;border:1.5px dashed var(--line-strong);margin:0 auto 20px;}
.card-service.placeholder .card-icon-frame::before,.card-service.placeholder .card-icon-frame::after{display:none;}
.card-service.placeholder h3{font-size:17px;}
.card-service.placeholder p{font-size:14px;margin-bottom:22px;}
.card-service.placeholder:hover{border-color:var(--amber);transform:translateY(-6px) scale(1.02);box-shadow:0 20px 44px -16px rgba(0,0,0,.5);}

/* ---------- Process ---------- */
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;}
@media (max-width:900px){.process-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:540px){.process-grid{grid-template-columns:1fr;}}
.process-step{position:relative;padding-top:8px;}
.process-step .step-no{font-family:'IBM Plex Mono';font-size:13px;color:var(--amber);margin-bottom:18px;display:block;}
.process-step h3{font-size:18px;margin-bottom:10px;}
.process-step p{color:var(--text-2);font-size:14px;}

/* ---------- Diferenciais ---------- */
.diff-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:10px;overflow:hidden;}
@media (max-width:900px){.diff-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:560px){.diff-grid{grid-template-columns:1fr;}}
.diff-item{background:var(--bg-panel);padding:34px 30px;display:flex;flex-direction:column;gap:14px;}
.diff-item .icon{color:var(--teal);width:28px;height:28px;}
.diff-item h3{font-size:16px;}
.diff-item p{color:var(--text-2);font-size:13.5px;}

/* ---------- Testimonials ---------- */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
@media (max-width:900px){.testi-grid{grid-template-columns:1fr;}}
.testi-card{background:var(--bg-panel);border:1px solid var(--line);border-radius:10px;padding:30px;}
.testi-card .quote-mark{font-family:'Space Grotesk';font-size:38px;color:var(--amber);line-height:1;margin-bottom:8px;display:block;}
.testi-card p{color:var(--text-2);font-size:14.5px;margin-bottom:24px;}
.testi-author strong{display:block;font-size:14.5px;font-family:'Space Grotesk';}
.testi-author span{font-size:12.5px;color:var(--text-3);}

/* ---------- Contact ---------- */
.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:40px;}
@media (max-width:900px){.contact-grid{grid-template-columns:1fr;}}
.contact-info{background:var(--bg-panel);border:1px solid var(--line);border-radius:10px;padding:34px;}
.contact-info h3{font-size:18px;margin-bottom:24px;}
.contact-row{display:flex;gap:14px;margin-bottom:20px;align-items:flex-start;}
.contact-row .icon{color:var(--amber);width:22px;height:22px;flex-shrink:0;margin-top:2px;}
.contact-row strong{display:block;font-size:14.5px;margin-bottom:3px;}
.contact-row span{font-size:13.5px;color:var(--text-2);}
.service-area{display:flex;flex-wrap:wrap;gap:8px;margin-top:26px;padding-top:26px;border-top:1px solid var(--line);}
.area-tag{font-family:'IBM Plex Mono';font-size:11.5px;color:var(--text-2);border:1px solid var(--line-strong);padding:5px 11px;border-radius:20px;}

.contact-form{background:var(--bg-panel);border:1px solid var(--line);border-radius:10px;padding:34px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;}
@media (max-width:560px){.form-row{grid-template-columns:1fr;}}
.field label{display:block;font-size:12.5px;color:var(--text-2);margin-bottom:7px;font-family:'IBM Plex Mono';letter-spacing:.02em;}
.field input,.field select,.field textarea{width:100%;background:var(--bg-deep);border:1px solid var(--line-strong);color:var(--text-1);padding:12px 14px;border-radius:6px;font-family:'Inter';font-size:16px;transition:border-color .2s ease;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--teal);}
.field-full{margin-bottom:18px;}
.field textarea{resize:vertical;min-height:100px;}
.form-note{font-size:12.5px;color:var(--text-3);margin-top:14px;text-align:center;}

/* ---------- Footer ---------- */
.site-footer{border-top:1px solid var(--line);padding:64px 0 32px;}
.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px;margin-bottom:48px;}
@media (max-width:900px){.footer-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:560px){.footer-grid{grid-template-columns:1fr;}}
.footer-brand .brand{margin-bottom:6px;}
.footer-brand p{color:var(--text-2);font-size:13.5px;margin-top:14px;max-width:280px;}
.footer-col h4{font-family:'IBM Plex Mono';font-size:11.5px;letter-spacing:.08em;color:var(--text-3);margin-bottom:18px;}
.footer-col ul li{margin-bottom:11px;}
.footer-col a{font-size:14px;color:var(--text-2);transition:color .2s ease;}
.footer-col a:hover{color:var(--text-1);}
.footer-col span{font-size:13.5px;color:var(--text-2);}
.footer-bottom{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;padding-top:28px;border-top:1px solid var(--line);font-size:12.5px;color:var(--text-3);}

/* ---------- Botões flutuantes (WhatsApp + Instagram) ---------- */
.float-stack{position:fixed;bottom:calc(22px + env(safe-area-inset-bottom));right:calc(22px + env(safe-area-inset-right));z-index:200;display:flex;flex-direction:column;align-items:center;gap:14px;}
.float-btn{position:relative;width:58px;height:58px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 28px -6px rgba(0,0,0,.55);transition:transform .25s ease, box-shadow .25s ease;}
.float-btn:hover{transform:translateY(-3px) scale(1.06);box-shadow:0 14px 32px -8px rgba(0,0,0,.6);}
.float-btn .icon{width:26px;height:26px;}
.float-btn.wa{background:#25D366;color:#0A2417;}
.float-btn.ig{background:radial-gradient(circle at 30% 110%, #FEDA75 0%, #FA7E1E 25%, #D62976 50%, #962FBF 75%, #4F5BD5 100%);color:#FFFFFF;}
.float-pulse{position:absolute;inset:0;border-radius:50%;border:2px solid #25D366;animation:pulsering 2.2s ease-out infinite;}
@media (max-width:480px){
  .float-stack{gap:12px;}
  .float-btn{width:52px;height:52px;}
  .float-btn .icon{width:23px;height:23px;}
}

/* ---------- Reveal ---------- */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s ease, transform .7s ease;}
.reveal.is-visible{opacity:1;transform:none;}

@media (prefers-reduced-motion:reduce){
  *{animation-duration:.001ms !important;animation-iteration-count:1 !important;transition-duration:.001ms !important;}
  .reveal{opacity:1;transform:none;}
}

/* Em telas de toque, os efeitos de hover não devem ficar "travados" após um toque */
@media (hover:none) and (pointer:coarse){
  .card-service:hover{transform:none;border-color:var(--line);background:var(--bg-panel);box-shadow:none;}
  .card-service.placeholder:hover{transform:none;border-color:var(--line-strong);box-shadow:none;}
  .card-cta:hover{transform:none;box-shadow:none;filter:none;}
  .btn-primary:hover{transform:none;box-shadow:none;}
  .btn-outline:hover{border-color:var(--line-strong);color:var(--text-1);}
  .card-service:active,.card-service.placeholder:active{transform:scale(.985);}
  .card-cta:active,.btn:active{transform:scale(.97);}
  .float-btn:hover{transform:none;box-shadow:0 10px 28px -6px rgba(0,0,0,.55);}
  .float-btn:active{transform:scale(.93);}
}
</style>
</head>
<body>

<div class="bg-grid" aria-hidden="true"></div>

<!-- ============ ICON LIBRARY (hidden, reused via <use>) ============ -->
