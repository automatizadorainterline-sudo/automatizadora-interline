<script>
// ===================================================================
// TROQUE AQUI: número de WhatsApp real da empresa (formato 55 + DDD + número, só dígitos)
const WHATSAPP_NUMBER = "5561991331033";
// ===================================================================

function buildWaLink(message){
  return "https://wa.me/" + WHATSAPP_NUMBER + "?text=" + encodeURIComponent(message);
}

document.addEventListener("DOMContentLoaded", function(){

  // preenche todos os links de WhatsApp com a mensagem certa
  document.querySelectorAll("[data-wa-msg]").forEach(function(el){
    el.setAttribute("href", buildWaLink(el.getAttribute("data-wa-msg")));
  });

  // formulário de contato -> abre WhatsApp com os dados preenchidos
  var form = document.getElementById("contact-form");
  if(form){
    form.addEventListener("submit", function(e){
      e.preventDefault();
      var nome = form.nome.value.trim();
      var telefone = form.telefone.value.trim();
      var servico = form.servico.value;
      var mensagem = form.mensagem.value.trim();

      var texto = "Olá! Meu nome é " + nome + ".";
      if(servico) texto += " Tenho interesse em: " + servico + ".";
      if(mensagem) texto += " " + mensagem;
      if(telefone) texto += " (Telefone para contato: " + telefone + ")";

      window.open(buildWaLink(texto), "_blank");
    });
  }

  // menu mobile
  var navToggle = document.getElementById("nav-toggle");
  var nav = document.getElementById("site-nav");
  if(navToggle && nav){
    navToggle.addEventListener("click", function(){
      var open = nav.classList.toggle("is-open");
      navToggle.classList.toggle("is-active");
      navToggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
    nav.querySelectorAll("a").forEach(function(a){
      a.addEventListener("click", function(){
        nav.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  // header muda de aparência ao rolar a página
  var header = document.getElementById("site-header");
  window.addEventListener("scroll", function(){
    if(window.scrollY > 12) header.classList.add("is-scrolled");
    else header.classList.remove("is-scrolled");
  });

  // animação de revelação ao rolar
  var revealEls = document.querySelectorAll(".reveal");
  if("IntersectionObserver" in window){
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          entry.target.classList.add("is-visible");
          obs.unobserve(entry.target);
        }
      });
    }, {threshold:0.15});
    revealEls.forEach(function(el){ obs.observe(el); });
  } else {
    revealEls.forEach(function(el){ el.classList.add("is-visible"); });
  }

});
</script>

